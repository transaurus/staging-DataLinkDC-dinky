{
  "name": "docs",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "clear": "docusaurus clear",
    "build": "docusaurus build",
    "start": "docusaurus start",
    "start-zh": "docusaurus start --locale zh-CN",
    "deploy": "docusaurus deploy",
    "docusaurus": "docusaurus",
    "swizzle": "docusaurus swizzle",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations --locale en && docusaurus write-translations --locale zh",
    "write-heading-ids": "docusaurus write-heading-ids --overwrite"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/plugin-ideal-image": "^3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@easyops-cn/docusaurus-search-local": "^0.52.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "docusaurus-plugin-less": "^2.0.2",
    "less-loader": "^12.3.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "less": "^4.4.1",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "supportedArchitectures": {
      "libc": [
        "glibc",
        "musl"
      ]
    },
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
